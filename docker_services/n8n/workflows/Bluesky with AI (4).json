      "id": "b5fd38a6-917c-4ea1-8d0f-a46bd1eae670",
      "name": "IsBot"
    },
    {
      "parameters": {
        "jsCode": "// Récupérer les données d'entrée\nconst items = $input.all();\n\nreturn items.map(item => {\n  try {\n    // Extraire la réponse de l'IA\n    const choices = item.json.choices;\n    \n    if (!choices || !choices[0] || !choices[0].output || !choices[0].output[0]) {\n      throw new Error(\"Structure de réponse invalide : impossible de trouver choices[0].output[0]\");\n    }\n    \n    // Parser le JSON de la réponse\n    const responseText = choices[0].output[0];\n    const parsedResponse = JSON.parse(responseText);\n    \n    // Vérifier les champs requis\n    const champsManquants = [];\n    \n    if (parsedResponse.is_real_news === undefined) {\n      champsManquants.push('is_real_news');\n    }\n    \n    if (parsedResponse.confidence === undefined) {\n      champsManquants.push('confidence');\n    }\n    \n    // Si des champs manquent, lever une erreur\n    if (champsManquants.length > 0) {\n      throw new Error(`Il manque ${champsManquants.length} champ(s) : ${champsManquants.join(', ')}`);\n    }\n    \n    // Retourner les données validées\n    return {\n      json: {\n        is_real_news: parsedResponse.is_real_news,\n        confidence: parsedResponse.confidence\n      }\n    };\n    \n  } catch (error) {\n    throw new Error(`Erreur de validation : ${error.message}`);\n  }\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        64,
        -400
      ],
      "id": "d24c8dff-59cc-47f6-b871-310ba08086be",
      "name": "Output Verification",
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nfor (const item of $input.all()) {\n  item.json.myNewField = 1;\n}\n\nreturn $input.all();"
      },
