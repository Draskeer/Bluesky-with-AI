    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst choices = item.choices;\nconst text = choices?.[0]?.message?.content ?? choices?.[0]?.output?.[0] ?? '';\nfunction extract(t){ const m = t.match(/\\{[\\s\\S]*\\}/); if(!m) return null; try { return JSON.parse(m[0]); } catch(e){ return null; } }\nconst p = extract(text);\nif(!p) throw new Error('Reponse IA non-JSON: ' + text.slice(0,200));\nconst inner = (p.is_real_news !== undefined) ? p : (p.object || p.result || p);\nconst is_real = inner.is_real_news === true || inner.is_real_news === 'true';\nlet conf = inner.confidence;\nconf = typeof conf === 'number' ? conf : (parseFloat(conf) || 0);\nreturn [{ json: { is_fake: !is_real, confidence: conf } }];"
      },
      "type": "n8n-nodes-base.code",
