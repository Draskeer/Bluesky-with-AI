        "jsCode": "// Liste des flux RSS par catégorie\nconst feeds = [\n  // POLITIQUE\n  { url: 'https://feeds.bbci.co.uk/news/politics/rss.xml', category: 'politique', source: 'BBC' },\n  { url: 'https://feeds.reuters.com/reuters/politicsNews', category: 'politique', source: 'Reuters' },\n  { url: 'https://www.lemonde.fr/politique/rss_full.xml', category: 'politique', source: 'Le Monde' },\n  // FINANCE\n  { url: 'https://feeds.reuters.com/reuters/businessNews', category: 'finance', source: 'Reuters' },\n  { url: 'https://feeds.marketwatch.com/marketwatch/topstories/', category: 'finance', source: 'MarketWatch' },\n  { url: 'https://www.lesechos.fr/rss/rss_finance.xml', category: 'finance', source: 'Les Echos' },\n  // TECH\n  { url: 'https://techcrunch.com/feed/', category: 'tech', source: 'TechCrunch' },\n  { url: 'https://www.theverge.com/rss/index.xml', category: 'tech', source: 'The Verge' },\n  { url: 'https://feeds.arstechnica.com/arstechnica/index', category: 'tech', source: 'Ars Technica' }\n];\n\nreturn feeds.map(feed => ({ json: feed }));"
      },
