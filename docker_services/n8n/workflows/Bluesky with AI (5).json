    {
      "parameters": {
        "jsCode": "const msg = $('Data Verification').item.json.message;\nconst articles = $('Build Articles').item.json.articles || [];\nconst context = articles.map((a, i) => {\n  const score = (typeof a.score === 'number') ? a.score.toFixed(3) : '?';\n  return `${i + 1}. [similarite ${score}] ${a.title || ''} - ${a.summary || ''}`;\n}).join('\\n');\nconst prompt_input = `Voici des articles de vraies actualites similaires (base de reference) :\\n${context || '(aucun article similaire trouve)'}\\n\\nMessage a analyser : \"${msg}\"`;\nreturn [{ json: { prompt_input } }];"
      },
