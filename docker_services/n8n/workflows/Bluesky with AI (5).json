    {
      "parameters": {
        "jsCode": "// Parse le XML RSS et extrait les articles\nconst xml = $input.item.json.data || '';\nconst category = $input.item.json.category || 'general';\nconst source = $input.item.json.source || 'unknown';\n\nif (!xml || typeof xml !== 'string') {\n  return [];\n}\n\n// Extraction des items RSS avec regex\nconst items = [];\nconst itemRegex = /<item[^>]*>([\\s\\S]*?)<\\/item>/gi;\nlet match;\n\nwhile ((match = itemRegex.exec(xml)) !== null) {\n  const item = match[1];\n\n  const getTag = (tag) => {\n    const r = new RegExp(`<${tag}[^>]*><!\\\\[CDATA\\\\[([\\\\s\\\\S]*?)\\\\]\\\\]><\\/${tag}>|<${tag}[^>]*>([\\\\s\\\\S]*?)<\\/${tag}>`, 'i');\n    const m = item.match(r);\n    return m ? (m[1] || m[2] || '').trim() : '';\n  };\n\n  const title = getTag('title');\n  const description = getTag('description');\n  const link = getTag('link') || getTag('guid');\n  const pubDate = getTag('pubDate') || getTag('published') || new Date().toISOString();\n  const author = getTag('author') || getTag('dc:creator') || source;\n\n  if (!title) continue;\n\n  // Nettoyage HTML basique\n  const cleanText = (str) => str\n    .replace(/<[^>]+>/g, ' ')\n    .replace(/&amp;/g, '&')\n    .replace(/&lt;/g, '<')\n    .replace(/&gt;/g, '>')\n    .replace(/&quot;/g, '\"')\n    .replace(/&#39;/g, \"'\")\n    .replace(/\\s+/g, ' ')\n    .trim();\n\n  const cleanTitle = cleanText(title);\n  const cleanDesc = cleanText(description);\n\n  // Texte complet pour l'embedding\n  const fullText = `${cleanTitle}. ${cleanDesc}`;\n\n  // ID unique basé sur l'URL\n  const id = Buffer.from(link || cleanTitle).toString('base64').replace(/[^a-zA-Z0-9]/g, '').substring(0, 32);\n\n  items.push({\n    json: {\n      id,\n      title: cleanTitle,\n      description: cleanDesc,\n      text: fullText,\n      url: link,\n      source,\n      category,\n      published_at: new Date(pubDate).toISOString(),\n      fetched_at: new Date().toISOString()\n    }\n  });\n}\n\nreturn items.slice(0, 20); // Max 20 articles par source"
      },
      "id": "7fe5743a-b300-43d9-a447-1e9fda50491c",
      "name": "🔍 Parse RSS",
